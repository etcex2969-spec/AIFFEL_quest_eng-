    {
      "cell_type": "code",
      "source": [
        "def score_analysis(name):\n",
        "    scores = {\"유원영\" : {\"국어\": 94, \"영어\": 91, \"수학\": 89},\n",
        "              \"설지민\" : {\"국어\": 88, \"영어\": 96, \"수학\": 90},\n",
        "              \"신윤아\" : {\"국어\": 86, \"영어\": 88, \"수학\": 77},\n",
        "              \"장윤아\" : {\"국어\": 98, \"영어\": 76, \"수학\": 92}}\n",
        "\n",
        "    # Calculate class averages\n",
        "    subjects = [\"국어\", \"영어\", \"수학\"]\n",
        "    class_subject_sums = {subject: 0 for subject in subjects}\n",
        "\n",
        "    for student_scores in scores.values():\n",
        "        for subject in subjects:\n",
        "            class_subject_sums[subject] += student_scores[subject]\n",
        "\n",
        "    num_students = len(scores)\n",
        "    avg_kor = class_subject_sums[\"국어\"] / num_students\n",
        "    avg_eng = class_subject_sums[\"영어\"] / num_students\n",
        "    avg_math = class_subject_sums[\"수학\"] / num_students\n",
        "\n",
        "    class_total_avg = (avg_kor + avg_eng + avg_math) / len(subjects)\n",
        "\n",
        "    # Get individual student scores\n",
        "    my_scores = scores[name]\n",
        "    my_kor = my_scores[\"국어\"]\n",
        "    my_eng = my_scores[\"영어\"]\n",
        "    my_math = my_scores[\"수학\"]\n",
        "\n",
        "    my_total_avg = (my_kor + my_eng + my_math) / len(subjects)\n",
        "\n",
        "    # Calculate differences\n",
        "    diff_kor = round(my_kor - avg_kor, 2)\n",
        "    diff_eng = round(my_eng - avg_eng, 2)\n",
        "    diff_math = round(my_math - avg_math, 2)\n",
        "    diff_total = round(my_total_avg - class_total_avg, 2)\n",
        "\n",
        "    # Print formatted output\n",
        "    print(f\"[{name} 성적 분석]\")\n",
        "\n",
        "    print(f\"국어: {my_kor}점, 학급 평균({avg_kor:.2f}점) 대비 {diff_kor:+.2f}\")\n",
